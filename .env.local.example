# Auth NextAuth
NEXTAUTH_SECRET=                    # Générer avec : openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000  # URL de production : https://mon-app.vercel.app

# Utilisateurs (nom:hash_bcrypt — générer avec bcryptjs.hash("motdepasse", 10))
AUTH_USER_1=admin:$2b$10$...        # Remplacer par un vrai hash bcrypt
AUTH_USER_2=                        # Optionnel
AUTH_USER_3=                        # Optionnel
AUTH_USER_4=                        # Optionnel
AUTH_USER_5=                        # Optionnel

# APIs
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Backend (optionnel — si vous avez une API externe)
API_URL=https://...
API_PUBLISH_TOKEN=...

# Resend (envoi email)
RESEND_API_KEY=re_...               # https://resend.com → API Keys
RESEND_FROM={{NOM_ENTREPRISE}} <contact@{{DOMAINE}}>

# Supabase (base de données)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...    # Project Settings → Data API → service_role
